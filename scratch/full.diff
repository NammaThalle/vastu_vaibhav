+def main():
+    # Make sure we have full.diff
+    run_cmd("git add -N .")
+    run_cmd("git diff > scratch/full.diff")
+    
+    files = get_patches()
+    actions = generate_commits(files)
+    
+    # Reset index to clean, leaving working tree as is
+    run_cmd("git reset")
